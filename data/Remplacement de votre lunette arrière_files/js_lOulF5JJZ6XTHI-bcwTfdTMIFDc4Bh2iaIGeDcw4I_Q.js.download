(function(Drupal,drupalSettings){window.doPush=function(event){let eventData={event};dataLayer.push(eventData);};let secondaryNav=document.querySelector('nav[aria-label="secondary"]');if(secondaryNav.querySelector('.btn-appointment'))secondaryNav.querySelector('.btn-appointment').addEventListener('click',function(){doPush('click_header_appointment');});if(secondaryNav.querySelector('.btn-contact'))secondaryNav.querySelector('.btn-contact').addEventListener('click',function(){doPush('click_header_contact');});if(secondaryNav.querySelector('.btn-call'))secondaryNav.querySelector('.btn-call').addEventListener('click',function(){doPush('click_header_to_call');});let storeLocatorForms=document.querySelectorAll('.itr-centers-locator-search-form');if(storeLocatorForms)storeLocatorForms.forEach(function(form){form.querySelector('.btn-primary').addEventListener('click',function(){doPush('click_on_page_store_locator');});});let highlightedBannerContactParagraph=document.querySelector('.paragraph--type--from-library .paragraph--type--highlighted-banner');if(highlightedBannerContactParagraph)highlightedBannerContactParagraph.querySelector('.btn-secondary').addEventListener('click',function(){doPush('click_on_page_appointment');});let partooWidget=document.querySelector('partoo-msg-widget');if(partooWidget){let shadowRoot=partooWidget.shadowRoot;shadowRoot.querySelector('#web-redirection-button-container a').addEventListener('click',function(){doPush('click_whatsapp_web');});}})(Drupal,drupalSettings);;
